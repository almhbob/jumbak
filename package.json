{
  "name": "jumbak",
  "version": "0.1.0",
  "private": true,
  "description": "Jnbk - Rickshaw ride-hailing app for Rufaa, Sudan",
  "scripts": {
    "dev": "pnpm --parallel --filter @jumbak/server --filter @jumbak/admin dev",
    "server:dev": "pnpm --filter @jumbak/server dev",
    "admin:dev": "pnpm --filter @jumbak/admin dev",
    "mobile:start": "pnpm --filter @jumbak/mobile start",
    "build": "pnpm --filter @jumbak/server build",
    "start": "pnpm --filter @jumbak/server start:prod",
    "railway:build": "pnpm install --frozen-lockfile=false && pnpm --filter @jumbak/server build",
    "railway:start": "pnpm --filter @jumbak/server prisma:deploy && pnpm --filter @jumbak/server start:prod",
    "lint": "eslint \"server/src/**/*.ts\" \"apps/mobile/src/**/*.ts\" \"apps/mobile/app/**/*.tsx\"",
    "lint:fix": "eslint --fix \"server/src/**/*.ts\" \"apps/mobile/src/**/*.ts\" \"apps/mobile/app/**/*.tsx\"",
    "format": "prettier --write \"server/src/**/*.ts\" \"apps/mobile/src/**/*.ts\" \"apps/mobile/app/**/*.tsx\" \"apps/admin/app/**/*.tsx\"",
    "test": "pnpm --filter @jumbak/server test"
  },
  "workspaces": [
    "apps/*",
    "server"
  ],
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.12.0",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3"
  }
}
