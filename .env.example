# Jnbk environment template
# Copy only the variables needed by each service.

# Server / Railway
DATABASE_URL=postgresql://user:password@host:5432/database
JWT_SECRET=replace-with-a-long-random-secret
NODE_ENV=production
PORT=4000
ALLOWED_ORIGINS=https://jnbk-admin.pages.dev,https://jumbak-admin.vercel.app

# Admin / Vercel or Cloudflare Pages
NEXT_PUBLIC_API_URL=https://YOUR-RAILWAY-BACKEND.up.railway.app

# Mobile / Expo EAS
EXPO_PUBLIC_API_URL=https://YOUR-RAILWAY-BACKEND.up.railway.app
