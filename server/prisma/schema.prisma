generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PASSENGER
  DRIVER
  ADMIN
}

enum RideStatus {
  REQUESTED
  ACCEPTED
  ARRIVING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum SupportStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  CLOSED
}

enum TransactionType {
  TOPUP
  RIDE_PAYMENT
  REFUND
  DRIVER_EARNING
  WITHDRAWAL
}

enum StaffRole {
  OPERATIONS
  SUPERVISOR
  SUPPORT
  ACCOUNTANT
  FINANCE
  DEVELOPER
  BUSINESS
}

enum StaffStatus {
  ACTIVE
  PAUSED
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

model Country {
  id        String   @id
  nameAr    String
  nameEn    String
  currency  String
  cities    City[]
  createdAt DateTime @default(now())
}

model City {
  id        String   @id
  countryId String
  country   Country  @relation(fields: [countryId], references: [id])
  nameAr    String
  nameEn    String
  zones     Zone[]
  drivers   Driver[]
  rides     Ride[]
  createdAt DateTime @default(now())
}

model Zone {
  id        String   @id @default(cuid())
  cityId    String
  city      City     @relation(fields: [cityId], references: [id])
  nameAr    String
  nameEn    String
  category  String   @default("مرافق ومعالم")
  multiplier Float   @default(1)
  fixedFare Int?
  createdAt DateTime @default(now())
}

model VehicleType {
  id          String   @id
  nameAr      String
  nameEn      String
  baseFare    Int
  perKmFare   Int
  minimumFare Int
  isVisible   Boolean  @default(true)
  vehicles    Vehicle[]
  rides       Ride[]
  createdAt   DateTime @default(now())
}

model User {
  id                   String        @id @default(cuid())
  phone                String        @unique
  name                 String?
  role                 UserRole      @default(PASSENGER)
  otpCode              String?
  otpExpiresAt         DateTime?
  otpAttempts          Int           @default(0)
  dailyCancellations   Int           @default(0)
  lastCancellationDate DateTime?
  suspendedUntil       DateTime?
  createdAt            DateTime      @default(now())
  rides                Ride[]        @relation("PassengerRides")
  driver               Driver?
  deviceTokens         DeviceToken[]
  wallet               Wallet?
}

model Wallet {
  id           String               @id @default(cuid())
  userId       String               @unique
  user         User                 @relation(fields: [userId], references: [id])
  balance      Int                  @default(0)
  currency     String               @default("SDG")
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  transactions WalletTransaction[]
}

model WalletTransaction {
  id          String          @id @default(cuid())
  walletId    String
  wallet      Wallet          @relation(fields: [walletId], references: [id])
  amount      Int
  type        TransactionType
  description String?
  rideId      String?
  createdAt   DateTime        @default(now())
}

model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  platform  String   @default("expo")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StaffMember {
  id           String      @id @default(cuid())
  name         String
  phone        String?
  email        String?
  username     String      @unique
  passwordHash String
  role         StaffRole
  status       StaffStatus @default(ACTIVE)
  notes        String?
  lastLoginAt  DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model LegalDocument {
  key       String   @id
  titleAr   String
  titleEn   String
  contentAr String
  contentEn String
  status    String   @default("draft")
  version   Int      @default(1)
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Driver {
  id                String             @id @default(cuid())
  userId            String             @unique
  user              User               @relation(fields: [userId], references: [id])
  cityId            String
  city              City               @relation(fields: [cityId], references: [id])
  isOnline          Boolean            @default(false)
  isVerified        Boolean            @default(false)
  dailyRejections   Int                @default(0)
  lastRejectionDate DateTime?
  suspendedUntil    DateTime?
  violationCount    Int                @default(0)
  vehicle           Vehicle?
  rides             Ride[]             @relation("DriverRides")
  offers            RideOffer[]
  application       DriverApplication?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model Vehicle {
  id            String      @id @default(cuid())
  driverId      String      @unique
  driver        Driver      @relation(fields: [driverId], references: [id])
  vehicleTypeId String
  vehicleType   VehicleType @relation(fields: [vehicleTypeId], references: [id])
  plateNo       String?
  color         String?
  model         String?
}

model Ride {
  id               String      @id @default(cuid())
  passengerId      String?
  passenger        User?       @relation("PassengerRides", fields: [passengerId], references: [id])
  driverId         String?
  driver           Driver?     @relation("DriverRides", fields: [driverId], references: [id])
  cityId           String
  city             City        @relation(fields: [cityId], references: [id])
  vehicleTypeId    String
  vehicleType      VehicleType @relation(fields: [vehicleTypeId], references: [id])
  pickupLabel      String
  destinationLabel String
  stops            String?
  pickupLat        Float?
  pickupLng        Float?
  distanceKm       Float       @default(2)
  estimatedFare    Int
  finalFare        Int?
  status           RideStatus  @default(REQUESTED)
  rating           Int?
  offers           RideOffer[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model RideOffer {
  id          String      @id @default(cuid())
  rideId      String
  ride        Ride        @relation(fields: [rideId], references: [id])
  driverId    String
  driver      Driver      @relation(fields: [driverId], references: [id])
  status      OfferStatus @default(PENDING)
  offeredAt   DateTime    @default(now())
  respondedAt DateTime?

  @@unique([rideId, driverId])
}

model SupportRequest {
  id        String        @id @default(cuid())
  category  String
  message   String
  lang      String        @default("ar")
  phone     String?
  name      String?
  status    SupportStatus @default(OPEN)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model PlatformSetting {
  key       String   @id
  value     String
  updatedBy String?
  updatedAt DateTime @updatedAt
}

model DriverApplication {
  id               String    @id @default(cuid())
  driverId         String?   @unique
  driver           Driver?   @relation(fields: [driverId], references: [id])
  phone            String
  name             String
  cityId           String?
  vehicleTypeId    String?
  plateNo          String?
  color            String?
  model            String?
  nationalId       String?
  chassisNo        String?
  trafficId        String?
  bankAccount      String?
  guarantorName    String?
  guarantorPhone   String?
  guarantorAddress String?
  status           String    @default("pending_review")
  complianceStatus String    @default("needs_admin_review")
  freeMonth        Boolean   @default(true)
  approvedAt       DateTime?
  rejectedAt       DateTime?
  reviewedBy       String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}