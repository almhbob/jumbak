# Database (required for production)
DATABASE_URL=postgresql://user:password@host:5432/jnbk

# JWT secret — generate a strong random string:  openssl rand -hex 32
JWT_SECRET=change-this-to-a-strong-random-secret

# Port (Railway sets this automatically)
PORT=4000

# CORS allowed origins — comma-separated, no trailing slash
ALLOWED_ORIGINS=https://jumbak-admin.vercel.app,http://localhost:3001

# Firebase Admin SDK — for verifying user phone auth tokens
# Get these from Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
