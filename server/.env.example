# ─────────────────────────────────────────────────────────────────────────────
# JNBK SERVER — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ─────────────────────────────────────────────────────────────────

# PostgreSQL connection string (Railway provides DATABASE_URL automatically)
DATABASE_URL=postgresql://user:password@host:5432/jnbk

# JWT signing secret — generate with:  node -e "require('crypto').randomBytes(32).toString('hex')"
JWT_SECRET=replace_with_64_char_hex_secret

# Developer account password — separate from staff, must be changed after first login
DEV_STAFF_PASSWORD=change_me_in_production

# Comma-separated allowed frontend origins (no trailing slash)
# https://jnbk-admin.pages.dev is included in code defaults; add custom domains here
ALLOWED_ORIGINS=https://jnbk-admin.pages.dev,https://yourdomain.com

# ── Optional ─────────────────────────────────────────────────────────────────

# Server port — Railway sets PORT automatically; only set this locally
PORT=4000

NODE_ENV=production

# OTP override for test/staging — omit entirely in production to enforce real SMS provider
# OTP_OVERRIDE=123456

# ── SMS — Africa's Talking (required in production for real OTP) ─────────────
# Sign up at https://africastalking.com — free sandbox for testing
# Set AT_USERNAME=sandbox and AT_API_KEY=sandbox-key for the AT sandbox
AT_USERNAME=your_africastalking_username
AT_API_KEY=your_africastalking_api_key

# ── Logging ──────────────────────────────────────────────────────────────────
# Log level: error | warn | info | debug  (default: info)
LOG_LEVEL=info

# ── Sentry (optional — error monitoring) ────────────────────────────────────
# Get your DSN from https://sentry.io → Project Settings → Client Keys
# Leave unset to disable Sentry
SENTRY_DSN=

# ── Firebase Admin SDK (optional — enables Firestore) ────────────────────────
# Firebase Console → Project Settings → Service Accounts → Generate new private key

FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Escape newlines with \n inside the quoted value
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBg...\n-----END PRIVATE KEY-----\n"
